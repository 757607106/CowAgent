# Copy this file to .env.local when running python app.py on the host.
# It derives dependency credentials from .env.platform. Keep only the local
# source-code Web port different from Docker's WEB_PORT.

if [ -f ".env.platform" ]; then
  # shellcheck disable=SC1091
  source ".env.platform"
fi

PLATFORM_WEB_PORT=${PLATFORM_WEB_PORT:-${WEB_PORT:-9899}}
LOCAL_WEB_PORT=9901

COW_PLATFORM_DATABASE_URL=postgresql://${PLATFORM_POSTGRES_USER:-cowplatform}:${PLATFORM_POSTGRES_PASSWORD:-change-to-strong-db-secret}@127.0.0.1:${PLATFORM_POSTGRES_PORT:-55432}/${PLATFORM_POSTGRES_DB:-cowplatform}
COW_PLATFORM_REDIS_URL=redis://127.0.0.1:${PLATFORM_REDIS_PORT:-56379}/0
COW_PLATFORM_QDRANT_URL=http://127.0.0.1:${PLATFORM_QDRANT_HTTP_PORT:-56333}
COW_PLATFORM_MINIO_ENDPOINT=http://127.0.0.1:${PLATFORM_MINIO_API_PORT:-59000}
COW_PLATFORM_MINIO_ACCESS_KEY=${PLATFORM_MINIO_ROOT_USER:-change-to-prod-access}
COW_PLATFORM_MINIO_SECRET_KEY=${PLATFORM_MINIO_ROOT_PASSWORD:-change-to-strong-minio-secret}
COW_PLATFORM_MINIO_BUCKET=${PLATFORM_MINIO_BUCKET:-cowagent}

COW_PLATFORM_ENV=dev
WEB_TENANT_AUTH=true
WEB_PORT=${LOCAL_WEB_PORT}
MODEL=${MODEL:-qwen3.6-plus}
AGENT_WORKSPACE=${AGENT_WORKSPACE:-$HOME/cow}
