# Copy this file to .env.local when running python app.py on the host.
# Dependencies always come from the Docker stack configured by .env.docker.
# Keep only host-process overrides here.

LOCAL_WEB_PORT=9901

COW_PLATFORM_ENV=dev
WEB_TENANT_AUTH=true
WEB_PORT=${LOCAL_WEB_PORT}
MODEL=${MODEL:-qwen3.6-plus}
AGENT_WORKSPACE=${AGENT_WORKSPACE:-$HOME/cow}
